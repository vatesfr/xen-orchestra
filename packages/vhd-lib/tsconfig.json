{
  "compilerOptions": {
    "allowJs": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "target": "ES2022",
    "skipLibCheck": true,
    "outDir": "dist",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "types": ["node"] // Only use types from Node.js and packages that are explicitly imported
  },
  "include": ["./*.js", "./Vhd/*.js"],
  "exclude": [
    "./dist",
    "./node_modules",
    "./*.integ.js",
    "./*.test.js",
    "./Vhd/*.integ.js",
    "./Vhd/*.test.js",
    "./tests"
  ]
}
