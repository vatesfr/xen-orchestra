  "homepage": "https://github.com/vatesfr/xen-orchestra/tree/master/packages/xo-server-package-manager",
  "bugs": "https://github.com/vatesfr/xen-orchestra/issues",
  "repository": {
    "directory": "packages/xo-server-package-manager",
    "type": "git",
    "url": "https://github.com/vatesfr/xen-orchestra.git"
  },
  "author": {
    "name": "Vates SAS",
    "url": "https://vates.fr"
  },
  "bin": {
