{
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./",
    "allowJs": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "target": "ES2022",
    "skipLibCheck": true,
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "types": ["node"] // Only use types from Node.js and packages that are explicitly imported
  },
  "include": ["./disks/**/*"],
  "exclude": ["./dist", "./node_modules"]
}
