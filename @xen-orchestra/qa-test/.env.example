# ===========================================
# XEN ORCHESTRA QA TEST CONFIGURATION
# ===========================================

# Core Connection Settings (Required)
HOSTNAME=http://localhost:9000
USERNAME=admin@admin.net
PASSWORD=admin

# Basic Test Configuration
VM_PREFIX=TST
REFERENCE_VM_ID=  # Required: UUID of the reference VM to clone for tests
SR_ID=  # Required: UUID of the Storage Repository for health checks
BACKUP_REPOSITORY_NAME=Test backup QA

# Test Backup Paths
# IMPORTANT: Only test-scoped paths are allowed for automatic cleanup
# Paths must contain 'test', 'qa', or 'tmp/xo' to prevent production data deletion
BACKUP_REPOSITORY_PATH=/tmp/xo-test-backups

# Production Backup Path (used for backup repository creation, NOT for cleanup)
# This path is NOT included in automatic cleanup to protect production data
BACKUP_PATH=/var/lib/xo/backups

# ===========================================
# VHD/XVA EXPORT TEST CONFIGURATION
# ===========================================

# Directory for VHD/XVA export files
# Must be a test-scoped path (containing 'test', 'qa', or 'tmp/') for cleanup safety
VHD_EXPORT_PATH=/tmp/xo-test-exports
